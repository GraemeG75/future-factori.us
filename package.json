{
  "name": "future-factori.us",
  "version": "0.2.0",
  "description": "Future Factorius - a factory-building game",
  "main": "electron/main.cjs",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:desktop": "tsc && vite build --config vite.config.electron.ts",
    "desktop:dev": "concurrently -k \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "desktop:pack": "npm run build:desktop && electron-builder --publish never",
    "desktop:pack:steam": "npm run build:desktop && electron-builder --dir --publish never",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "preview": "vite preview"
  },
  "dependencies": {
    "three": "^0.183.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.0",
    "@types/node": "^25.6.0",
    "@types/three": "^0.183.0",
    "concurrently": "^9.2.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.13.0",
    "jsdom": "^29.0.2",
    "less": "^4.2.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "8.10.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0",
    "wait-on": "^9.0.5"
  },
  "browserslist": {
    "production": [
      "> 0.5%",
      "last 2 versions",
      "Firefox ESR",
      "not dead",
      "not IE 9-11",
      "not kaiOS <= 100",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
